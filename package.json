{
  "name": "caliburn-marketplace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "lint:jsx": "eslint . --ext .js,.jsx --no-eslintrc --config ./eslint.config.js",
    "validate:jsx": "node jsx-validator.js",
    "validate:jsx:strict": "node jsx-validator.js --strict",
    "prebuild": "npm run test:jsx && npm run typecheck",
    "predev:disabled": "npm run validate:jsx:quick",
    "validate:jsx:quick": "npm run validate:jsx || (echo '⚠️ JSX validation failed but continuing...' && exit 0)",
    "preview": "vite preview",
    "test": "npm run test:jsx && npm run typecheck",
    "test:jsx": "npm run validate:jsx && npm run lint:jsx",
    "test:jsx:fix": "npm run validate:jsx && npx eslint --fix . --ext .js,.jsx",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "prepare": "husky",
    "jsx:doctor": "node jsx-validator.js --verbose",
    "jsx:emergency-fix": "npx eslint --fix . --ext .js,.jsx && npm run validate:jsx"
  },
  "dependencies": {
    "jspdf": "^3.0.4",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.552.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-leaflet": "^5.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
