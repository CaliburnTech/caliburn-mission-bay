{
  "name": "caliburn-marketplace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "prisma generate && tsc && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "npm run lint && npm run typecheck && vitest run",
    "prebuild": "npm run lint && npm run typecheck",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1052.0",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/client-ses": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.106.1",
    "@types/pg": "^8.20.0",
    "@xyflow/react": "^12.10.1",
    "aws-jwt-verify": "^5.1.1",
    "dotenv": "^17.4.2",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.576.0",
    "mermaid": "^11.15.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-leaflet": "^5.0.0",
    "resend": "^6.12.3",
    "svix": "^1.93.0",
    "tldraw": "^4.5.3",
    "uri-js": "^4.4.1",
    "zustand": "^5.0.8"
  },
  "prisma": {
    "seed": "node --import tsx/esm prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.3.3",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitejs/plugin-react": "^5.0.4",
    "acorn": "^8.17.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
