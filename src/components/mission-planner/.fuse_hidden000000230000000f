const T_START            =   5;
const T_DECOY_ACTIVE     =  16;   // emitter projects a frigate-class signature
const T_ADVERSARY_DETECT =  30;   // enemy coastal radar paints the phantom contact
const T_UAV_LAUNCH       =  40;   // enemy tasks + launches a high-value ISR UAV
const T_UAV_ARRIVE       =  84;   // UAV reaches the decoy (long, costly transit)
const T_UAV_INVESTIGATE  =  94;   // UAV loiters / photographs
const T_UAV_RTB          = 106;   // nothing of value — UAV turns for home
const T_WASTE_TALLY      = 116;   // cost-imposition payoff
const TOTAL_TICKS        = 128;

const TICK_MS = 280;

// ─── Tile layers ──────────────────────────────────────────────────────────────
const TILE_BASE    = 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png';
const TILE_SEAMARK = 'https://tiles.openseamap.org/seamark/{z}/{x}/{y}.png';

// ─── Helpers ─────────────────────────────────────────────────────────────────
const lerp2 = (a, b, t) => [a[0] + (b[0] - a[0]) * t, a[1] + (b[1] - a[1]) * t];

const trackPos = (track, t) => {
  const clamped = Math.min(Math.max(t, 0), 0.9999);
  const progress = clamped * (track.length - 1);
  const idx = Math.floor(progress);
  return lerp2(track[idx], track[idx + 1], progress - idx);
};

const EVENT_COLORS = {
  warn:    'text-amber-400',
  alert:   'text-red-400',
  info:    'text-cyan-400',
  success: 'text-emerald-400',
};

// ─── Phase narratives ─────────────────────────────────────────────────────────
const PHASE_NARRATIVE = {
  idle:             null,
  onstation:        { title: 'Decoy On Station', body: 'A single low-cost SubSeaSail Horus loiters in open water. EW decoy payload warming up. The hull itself has a near-zero signature — a sailing drone the size of a surfboard.' },
