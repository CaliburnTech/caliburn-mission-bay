  [26.45, 120.25],
  [25.70, 120.95],
  [24.85, 121.60],
  [24.20, 122.15],   // arrives over the decoy
];
const UAV_RETURN = [
  [24.20, 122.15],
  [24.85, 121.60],
  [25.70, 120.95],
  [26.45, 120.25],
];

const DECOY_RCS_NM = 9;   // apparent frigate-class contact radius on adversary sensors

