// ─── Tick milestones ──────────────────────────────────────────────────────────
const T_INGRESS       =  6;
const T_BASKET        = 34;
const T_RELEASE_GATE  = 42;   // HITL #1 — release authorization
const T_RELEASE_AUTH  = 52;   // gate clears
const T_LAUNCH_USV    = 58;
const T_LAUNCH_UUV    = 66;
const T_LAUNCH_ALE    = 74;
const T_SWARM         = 82;
const T_TERMINAL_ISR  = 96;
const T_ENGAGE_GATE   = 104;  // HITL #2 — engage authorization
const T_ENGAGE_AUTH   = 114;  // gate clears — weapons free
const T_IMPACT        = 118;
const T_BDA           = 130;
const T_EGRESS        = 138;
const TOTAL_TICKS     = 168;
const TICK_MS         = 180;

// ─── Helpers ──────────────────────────────────────────────────────────────────
const lerp2 = (a, b, t) => [a[0] + (b[0] - a[0]) * t, a[1] + (b[1] - a[1]) * t];
const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v));

const getPhase = (tick) => {
  if (tick < T_INGRESS)      return 'idle';
  if (tick < T_BASKET)       return 'emcon_ingress';
  if (tick < T_RELEASE_GATE) return 'launch_basket_reached';
  if (tick < T_RELEASE_AUTH) return 'hitl_release_gate';
  if (tick < T_LAUNCH_UUV)   return 'launch_daughter_usvs';
  if (tick < T_LAUNCH_ALE)   return 'launch_uuv';
  if (tick < T_SWARM)        return 'launch_ale';
  if (tick < T_TERMINAL_ISR) return 'swarm_vector';
  if (tick < T_ENGAGE_GATE)  return 'terminal_ISR';
  if (tick < T_IMPACT)       return 'engage';
  if (tick < T_BDA)          return 'bda_confirm';
  return 'mothership_egress';
};

// Mothership: ingress → basket → hold → egress
const getMotherPos = (tick) => {
  if (tick < T_INGRESS)  return MOTHER_START;
  if (tick < T_BASKET) {
    const t = clamp((tick - T_INGRESS) / (T_BASKET - T_INGRESS), 0, 1);
    return lerp2(MOTHER_START, LAUNCH_BASKET, t);
  }
  if (tick < T_EGRESS)   return LAUNCH_BASKET;
  const t = clamp((tick - T_EGRESS) / (TOTAL_TICKS - T_EGRESS), 0, 1);
  return lerp2(LAUNCH_BASKET, MOTHER_EGRESS, t);
};

// Adversary picket drifts west along the strait once the scenario is running
const getPicketPos = (tick) => {
  const t = clamp(tick / TOTAL_TICKS, 0, 1);
  return lerp2(PICKET_START, PICKET_END, t);
};

// Daughter vehicle: appears at launch tick, vectors from basket toward target
const getDaughterPos = (tick, launchTick, target) => {
  if (tick < launchTick) return null;
  const t = clamp((tick - launchTick) / (T_ENGAGE_AUTH - launchTick), 0, 1);
  return lerp2(LAUNCH_BASKET, target, t);
};

const getBoomRadius  = (tick) => tick < T_IMPACT || tick >= T_IMPACT + 16 ? 0 : clamp((tick - T_IMPACT) / 16, 0, 1) * 22 * NM_TO_M;
const getBoomOpacity = (tick) => tick < T_IMPACT || tick >= T_IMPACT + 16 ? 0 : Math.max(0, 0.85 - (tick - T_IMPACT) * 0.06);

