#!/usr/bin/env sh

echo "Running pre-commit checks..."

npm run lint
if [ $? -ne 0 ]; then
  echo "Lint failed. Run 'npm run lint:fix' to auto-fix, then review remaining issues."
  exit 1
fi

npm run typecheck
if [ $? -ne 0 ]; then
  echo "Type check failed. Fix TypeScript errors before committing."
  exit 1
fi

echo "All checks passed."
