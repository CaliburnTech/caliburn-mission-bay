# Caliburn Mission Bay — Environment Variables
# Copy to .env.local for local development.
#
# VITE_ prefix = exposed to the browser bundle. Never put secrets in VITE_ vars.
# Supabase anon key is intentionally public (safe — RLS enforces access control).

# ── App mode ─────────────────────────────────────────────────────────────────
# 'demo'       — static data, no auth, no API calls (Vercel demo)
# 'production' — real Supabase backend
VITE_APP_MODE=demo

# ── Supabase (browser-safe — anon key is public) ──────────────────────────────
VITE_SUPABASE_URL=https://vmyuyljmycwtfpuwiusr.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xECPZXdl1JBnmh4ERIjDdg_gbfQeC8_
# Optional: override API base URL (defaults to Supabase Edge Functions)
# VITE_API_URL=https://api.missionbay.caliburn.us

# ── Prisma / database ────────────────────────────────────────────────────────
# Pooled connection (PgBouncer, transaction mode) — used by Prisma at runtime.
# Supabase dashboard → Settings → Database → Connection pooling → Transaction → URI (port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — used by Prisma for migrations (bypasses PgBouncer).
# Supabase dashboard → Settings → Database → Connection string → URI (port 5432)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ── Supabase Edge Functions / server-side only ────────────────────────────────
# These are auto-injected by the Supabase runtime in production.
# Set them in .env.local for testing with: supabase functions serve
SUPABASE_URL=https://vmyuyljmycwtfpuwiusr.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xECPZXdl1JBnmh4ERIjDdg_gbfQeC8_
# NEVER commit the service role key. Get from: Supabase dashboard → Settings → API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── API hardening ─────────────────────────────────────────────────────────────
# Comma-separated allowlist of browser origins for the Vercel api/ routes.
# Unset = '*' (permissive fallback — set this in production).
ALLOWED_ORIGINS=https://caliburn-marketplace.vercel.app,https://caliburn-marketplace-admin.vercel.app,https://mission-bay-maker.vercel.app,http://localhost:5173,http://localhost:5174

# Optional comma-separated super-admin allowlist. When set, an @caliburn.us
# email must ALSO appear here to pass requireCaliburnAdmin.
SUPER_ADMIN_EMAILS=admin@caliburn.us,ops@caliburn.us

# Set to 'true' to require super-admins to sign in via SSO (rejects email/password logins).
SUPER_ADMIN_REQUIRE_SSO=false
# Comma-separated Supabase identity providers accepted for admin SSO (default: azure,google,saml).
SUPER_ADMIN_SSO_PROVIDERS=azure,google,saml

# ── Auth webhooks ─────────────────────────────────────────────────────────────
# Shared secret for the Supabase auth.users database webhook (api/auth/webhook).
# REQUIRED in production — the endpoint fails closed (500) when unset.
# Generate: openssl rand -hex 32
SUPABASE_WEBHOOK_SECRET=your-webhook-secret-here

# Shared secret for the post-confirm Edge Function webhook.
# Generate: openssl rand -hex 32
AUTH_WEBHOOK_SECRET=your-webhook-secret-here

# Shared secret for internal events Edge Function calls.
EVENTS_WEBHOOK_SECRET=your-events-webhook-secret-here

# ── Email (pick one provider) ─────────────────────────────────────────────────
# Resend (transactional email)
RESEND_API_KEY=re_your_api_key_here
# Supabase local dev uses Inbucket (port 54324) — no config needed for local.

# From / notify addresses for transactional email
SES_FROM_ADDRESS=missions@caliburn.us
CALIBURN_NOTIFY_EMAIL=team@caliburn.us
CALIBURN_SALES_EMAIL=sales@caliburn.us

# ── AI bridge ─────────────────────────────────────────────────────────────────
# 32-byte hex key that AES-256-GCM-encrypts per-company Anthropic API keys at rest. Generate: openssl rand -hex 32
ANTHROPIC_KEY_ENCRYPTION_SECRET=your-64-hex-char-secret-here
# Optional shared Anthropic API key — fallback when a company has no key of its own.
# ANTHROPIC_API_KEY=sk-ant-...

# ── OAuth providers (configure in Supabase dashboard, not here) ───────────────
# Supabase Dashboard → Authentication → Providers
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# AZURE_CLIENT_ID=...       (for @caliburn.us staff SSO)
# AZURE_CLIENT_SECRET=...
