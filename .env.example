# Caliburn Mission Bay — Environment Variables
# Copy to .env.local for local development.
#
# VITE_ prefix = exposed to the browser bundle. Never put secrets in VITE_ vars.
# Supabase anon key is intentionally public (safe — RLS enforces access control).

# ── App mode ─────────────────────────────────────────────────────────────────
# 'demo'       — static data, no auth, no API calls (Vercel demo)
# 'production' — real Supabase backend
VITE_APP_MODE=demo

# ── Supabase (browser-safe — anon key is public) ──────────────────────────────
VITE_SUPABASE_URL=https://vmyuyljmycwtfpuwiusr.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xECPZXdl1JBnmh4ERIjDdg_gbfQeC8_
# Optional: override API base URL (defaults to Supabase Edge Functions)
# VITE_API_URL=https://api.missionbay.caliburn.us

# ── Supabase Edge Functions / server-side only ────────────────────────────────
# These are auto-injected by the Supabase runtime in production.
# Set them in .env.local for testing with: supabase functions serve
SUPABASE_URL=https://vmyuyljmycwtfpuwiusr.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xECPZXdl1JBnmh4ERIjDdg_gbfQeC8_
# NEVER commit the service role key. Get from: Supabase dashboard → Settings → API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Auth webhooks ─────────────────────────────────────────────────────────────
# Shared secret for the post-confirm Edge Function webhook.
# Generate: openssl rand -hex 32
AUTH_WEBHOOK_SECRET=your-webhook-secret-here

# Shared secret for internal events Edge Function calls.
EVENTS_WEBHOOK_SECRET=your-events-webhook-secret-here

# ── Email (pick one provider) ─────────────────────────────────────────────────
# Resend (recommended for Supabase projects)
# RESEND_API_KEY=re_...
# Supabase local dev uses Inbucket (port 54324) — no config needed for local.

# From / notify addresses for transactional email
SES_FROM_ADDRESS=missions@caliburn.us
CALIBURN_NOTIFY_EMAIL=team@caliburn.us
CALIBURN_SALES_EMAIL=sales@caliburn.us

# ── AI bridge ─────────────────────────────────────────────────────────────────
# Per-company Anthropic keys are stored in Supabase Vault (never in env).
# This key is a local dev fallback ONLY. Never use in production.
# ANTHROPIC_API_KEY=sk-ant-...

# ── OAuth providers (configure in Supabase dashboard, not here) ───────────────
# Supabase Dashboard → Authentication → Providers
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# AZURE_CLIENT_ID=...       (for @caliburn.us staff SSO)
# AZURE_CLIENT_SECRET=...
