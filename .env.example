# Caliburn Mission Bay Marketplace — Environment Variables
# Copy to .env.local for local development
#
# VITE_ prefix required for variables exposed to the browser.
# Never put secrets in VITE_ variables — they are bundled into the client.

# App mode: 'demo' (static data, no auth) or 'production' (API + auth)
VITE_APP_MODE=demo

# API base URL (production mode only)
# VITE_API_BASE_URL=/api

# Clerk auth (production mode only)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Anthropic API key for AI chat (optional, user can also enter in-app)
# VITE_ANTHROPIC_API_KEY=sk-ant-...
