# Supabase project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Main Mission Bay Vercel backend URL (where the api/ serverless functions are deployed).
# Must be the Vercel deployment — NOT the Supabase functions/v1 URL.
# For local dev (vercel dev / local API server) use: http://localhost:3000
VITE_API_URL=https://caliburn-marketplace.vercel.app
